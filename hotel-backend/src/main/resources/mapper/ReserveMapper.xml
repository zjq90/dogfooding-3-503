<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hotel.mapper.ReserveMapper">

    <delete id="deleteByRoomId">
        DELETE FROM t_book_a_room WHERE room_id = #{roomId}
    </delete>

    <select id="countByRoomId" resultType="int">
        SELECT COUNT(*) FROM t_book_a_room WHERE room_id = #{roomId}
    </select>
</mapper>
