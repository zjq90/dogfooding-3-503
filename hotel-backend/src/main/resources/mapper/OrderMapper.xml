<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hotel.mapper.OrderMapper">

    <resultMap id="BaseResultMap" type="com.hotel.entity.Order">
        <result column="room_id" jdbcType="VARCHAR" property="roomId"/>
        <result column="user_name" jdbcType="VARCHAR" property="userName"/>
        <result column="ID" jdbcType="VARCHAR" property="idCard"/>
        <result column="start_time" jdbcType="TIMESTAMP" property="startTime"/>
        <result column="end_time" jdbcType="TIMESTAMP" property="endTime"/>
        <result column="prepay" jdbcType="DECIMAL" property="prepay"/>
        <result column="payment" jdbcType="DECIMAL" property="payment"/>
        <result column="change" jdbcType="DECIMAL" property="change"/>
        <result column="ser_num" jdbcType="VARCHAR" property="serNum"/>
    </resultMap>

    <sql id="Base_Column_List">
        room_id, user_name, ID, start_time, end_time, prepay, payment, `change`, ser_num
    </sql>

    <insert id="insert" parameterType="com.hotel.entity.Order">
        INSERT INTO t_order (room_id, user_name, ID, start_time, end_time, prepay, payment, `change`)
        VALUES (#{roomId}, #{userName}, #{idCard}, NOW(), NULL, #{prepay}, #{payment}, #{change})
    </insert>

    <update id="updateByPrimaryKey" parameterType="com.hotel.entity.Order">
        UPDATE t_order
        SET user_name = #{userName},
            ID = #{idCard},
            start_time = #{startTime},
            end_time = #{endTime},
            prepay = #{prepay},
            payment = #{payment},
            `change` = #{change}
        WHERE room_id = #{roomId}
    </update>

    <delete id="deleteByPrimaryKey">
        DELETE FROM t_order WHERE room_id = #{roomId}
    </delete>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_order
        WHERE room_id = #{roomId}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_order
        ORDER BY start_time DESC
    </select>

    <select id="selectByPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_order
        ORDER BY start_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countAll" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM t_order
    </select>

    <select id="selectByUserName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_order
        WHERE user_name = #{userName}
        ORDER BY start_time DESC
    </select>

    <update id="checkOut">
        UPDATE t_order
        SET end_time = NOW()
        WHERE room_id = #{roomId}
    </update>

</mapper>
